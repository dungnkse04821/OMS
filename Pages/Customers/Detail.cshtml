@page
@model OMS.Pages.Customers.DetailModel
@{
    ViewData["Title"] = $"Chi tiết khách hàng — {Model.Customer.FullName}";
}

<style>
/* ── Customer Detail Styles ───────────────────────────────────── */
.customer-hero {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 28px;
    flex-wrap: wrap;
}
.customer-avatar-lg {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), #00f2fe);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; font-weight: 800;
    color: #0d111e;
    flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(0,242,254,0.25);
}
.customer-meta { flex: 1; min-width: 200px; }
.customer-meta h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 4px 0; }
.customer-meta .sub { color: var(--text-muted); font-size: 0.87rem; display: flex; flex-wrap: wrap; gap: 12px; }
.customer-meta .sub span { display: flex; align-items: center; gap: 5px; }

/* KPI Cards */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 14px;
    margin-bottom: 28px;
}
.kpi-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.18s, box-shadow 0.18s;
}
.kpi-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }
.kpi-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--kpi-color, var(--primary));
    border-radius: 14px 14px 0 0;
}
.kpi-label { font-size: 0.77rem; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.kpi-value { font-size: 1.35rem; font-weight: 800; color: var(--kpi-color, var(--text-primary)); line-height: 1.1; }
.kpi-sub   { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }

/* Status counts row */
.status-counts {
    display: flex; gap: 16px; flex-wrap: wrap;
    margin-bottom: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 14px 18px;
}
.status-count-item { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; }
.status-count-dot  { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
</style>

<div class="glass-card">
    @* Back nav + actions *@
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:24px;">
        <a href="/Customers" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);font-size:0.87rem;text-decoration:none;transition:color 0.15s;"
           onmouseover="this.style.color='#00f2fe'" onmouseout="this.style.color=''">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:16px;height:16px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            Danh sách khách hàng
        </a>
        <div style="display:flex;gap:8px;">
            <a href="/Customers/Edit?id=@Model.Customer.Id" class="btn-secondary-premium" style="padding:8px 14px;font-size:0.85rem;">
                ✏️ Sửa thông tin
            </a>
            <a href="/Orders?SearchQuery=@Uri.EscapeDataString(Model.Customer.PhoneNumber)" class="btn-premium" style="padding:8px 14px;font-size:0.85rem;">
                📋 Xem đơn hàng
            </a>
        </div>
    </div>

    @* Customer Hero *@
    <div class="customer-hero">
        <div class="customer-avatar-lg">
            @(Model.Customer.FullName.Length > 0 ? Model.Customer.FullName[0].ToString().ToUpper() : "?")
        </div>
        <div class="customer-meta">
            <h1>@Model.Customer.FullName</h1>
            <div class="sub">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:14px;height:14px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                    </svg>
                    @Model.Customer.PhoneNumber
                </span>
                @if (!string.IsNullOrEmpty(Model.Customer.Address))
                {
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:14px;height:14px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                        </svg>
                        @Model.Customer.Address
                    </span>
                }
                @if (!string.IsNullOrEmpty(Model.Customer.Reference))
                {
                    <span>🔗 @Model.Customer.Reference</span>
                }
                <span style="font-family:monospace;color:#00f2fe;font-size:0.82rem;">@Model.Customer.Id</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.Customer.Note))
            {
                <div style="margin-top:6px;font-size:0.83rem;color:var(--text-muted);font-style:italic;">
                    📝 @Model.Customer.Note
                </div>
            }
        </div>
    </div>

    @* ── Financial KPI Cards ── *@
    <div class="kpi-grid">
        <div class="kpi-card" style="--kpi-color:#00f2fe;">
            <div class="kpi-label">Tổng mua (excl. Hủy)</div>
            <div class="kpi-value">@Model.TotalRevenue.ToString("N0") ₫</div>
            <div class="kpi-sub">@Model.TotalOrders tổng đơn / @(Model.TotalOrders - Model.CancelledOrders) hợp lệ</div>
        </div>
        <div class="kpi-card" style="--kpi-color:#10b981;">
            <div class="kpi-label">Đã thanh toán</div>
            <div class="kpi-value">@Model.TotalPaid.ToString("N0") ₫</div>
            <div class="kpi-sub">
                @if (Model.TotalRevenue > 0)
                { <span>@((Model.TotalPaid / Model.TotalRevenue * 100).ToString("N0"))% tổng tiền</span> }
                else
                { <span>—</span> }
            </div>
        </div>
        <div class="kpi-card" style="--kpi-color:@(Model.TotalDebt > 0 ? "#ef4444" : "#10b981");">
            <div class="kpi-label">Còn nợ</div>
            <div class="kpi-value">
                @if (Model.TotalDebt > 0)
                { @Model.TotalDebt.ToString("N0") <text> ₫</text> }
                else
                { <text>Đã thanh toán hết ✓</text> }
            </div>
            <div class="kpi-sub">
                @if (Model.TotalDebt > 0)
                { <span>Còn @(Model.Orders.Count(o => o.RemainingAmount > 0 && o.Status != "Hủy")) đơn chưa TT</span> }
            </div>
        </div>
        @if (Model.TotalDiscount > 0)
        {
            <div class="kpi-card" style="--kpi-color:#f59e0b;">
                <div class="kpi-label">Chiết khấu</div>
                <div class="kpi-value">@Model.TotalDiscount.ToString("N0") ₫</div>
                <div class="kpi-sub">Tổng ưu đãi nhận được</div>
            </div>
        }
        <div class="kpi-card" style="--kpi-color:#a78bfa;">
            <div class="kpi-label">Đơn đã giao</div>
            <div class="kpi-value">@Model.DeliveredOrders</div>
            <div class="kpi-sub">/ @Model.TotalOrders tổng đơn</div>
        </div>
    </div>

    @* ── Order status summary ── *@
    @if (Model.TotalOrders > 0)
    {
        <div class="status-counts">
            <span style="font-size:0.82rem;color:var(--text-muted);font-weight:600;margin-right:4px;">Trạng thái:</span>
            @{
                var statusInfo = new[] {
                    ("Chờ đặt",  "#f59e0b", Model.Orders.Count(o => o.Status == "Chờ đặt")),
                    ("Đã đặt",   "#a78bfa", Model.Orders.Count(o => o.Status == "Đã đặt")),
                    ("Đang về",  "#38bdf8", Model.Orders.Count(o => o.Status == "Đang về")),
                    ("Đã về",    "#00f2fe", Model.Orders.Count(o => o.Status == "Đã về")),
                    ("Đã giao",  "#10b981", Model.Orders.Count(o => o.Status == "Đã giao")),
                    ("Hủy",      "#ef4444", Model.Orders.Count(o => o.Status == "Hủy")),
                };
            }
            @foreach (var (status, color, count) in statusInfo)
            {
                if (count > 0)
                {
                    <div class="status-count-item">
                        <div class="status-count-dot" style="background:@color;"></div>
                        <span style="color:@color;font-weight:600;">@count</span>
                        <span style="color:var(--text-muted);">@status</span>
                    </div>
                }
            }
        </div>
    }

    @* ── Order History Table ── *@
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
        <h2 style="font-size:1.05rem;font-weight:700;margin:0;">
            📦 Lịch sử đơn hàng
            <span style="font-size:0.82rem;color:var(--text-muted);font-weight:400;margin-left:6px;">(@Model.TotalOrders đơn)</span>
        </h2>
        <a href="/Orders/Create?phone=@Uri.EscapeDataString(Model.Customer.PhoneNumber)&name=@Uri.EscapeDataString(Model.Customer.FullName)"
           class="btn-secondary-premium" style="padding:7px 14px;font-size:0.82rem;">
            + Tạo đơn mới
        </a>
    </div>

    @if (!Model.Orders.Any())
    {
        <div style="text-align:center;padding:40px;color:var(--text-muted);">
            <div style="font-size:2rem;margin-bottom:10px;">📭</div>
            <p>Khách hàng này chưa có đơn hàng nào.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="custom-table" style="font-size:0.87rem;">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Ngày đặt</th>
                        <th>Sản phẩm</th>
                        <th style="text-align:right;">SL</th>
                        <th style="text-align:right;">Tổng tiền</th>
                        <th style="text-align:right;">Đã cọc</th>
                        <th style="text-align:right;">Còn lại</th>
                        <th>Trạng thái</th>
                        <th>Ngày về</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        string badge = order.Status switch {
                            "Chờ đặt" => "pending",
                            "Đã đặt"  => "ordered",
                            "Đang về" => "shipping",
                            "Đã về"   => "arrived",
                            "Đã giao" => "delivered",
                            "Hủy"     => "cancelled",
                            _ => "pending"
                        };
                        bool hasDebt = order.RemainingAmount > 0 && order.Status != "Hủy";
                        <tr style="@(order.Status == "Hủy" ? "opacity:0.55;" : "")">
                            <td style="font-family:monospace;color:#00f2fe;font-weight:600;">
                                <a href="/Orders/Edit?id=@order.Id" style="color:inherit;">@order.Id</a>
                            </td>
                            <td style="white-space:nowrap;">@(order.OrderDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>
                                <div style="font-weight:500;">@order.ProductName</div>
                                @if (!string.IsNullOrEmpty(order.Code))
                                { <div style="font-size:0.75rem;color:var(--text-muted);">@order.Code</div> }
                                @if (!string.IsNullOrEmpty(order.Color) || !string.IsNullOrEmpty(order.Size))
                                {
                                    <div style="font-size:0.75rem;color:var(--text-muted);">
                                        @(order.Color) @(!string.IsNullOrEmpty(order.Color) && !string.IsNullOrEmpty(order.Size) ? "/" : "") @(order.Size)
                                    </div>
                                }
                            </td>
                            <td style="text-align:right;">@order.Quantity</td>
                            <td style="text-align:right;font-weight:600;">@order.TotalAmount.ToString("N0") ₫</td>
                            <td style="text-align:right;">@order.Deposit.ToString("N0") ₫</td>
                            <td style="text-align:right;font-weight:600;color:@(hasDebt ? "#ef4444" : "#10b981");">
                                @if (hasDebt)
                                { <span>@order.RemainingAmount.ToString("N0") ₫</span> }
                                else if (order.Status != "Hủy")
                                { <span>✓ Đã TT</span> }
                                else
                                { <span>—</span> }
                            </td>
                            <td><span class="status-badge @badge">@order.Status</span></td>
                            <td style="white-space:nowrap;color:var(--text-muted);font-size:0.82rem;">
                                @(order.ArrivalDate?.ToString("dd/MM/yy") ?? "-")
                            </td>
                            <td>
                                <a href="/Orders/Edit?id=@order.Id" class="action-btn edit" title="Sửa đơn">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487z" />
                                    </svg>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                @* Footer totals row *@
                <tfoot>
                    <tr style="font-weight:700;background:rgba(0,242,254,0.04);border-top:2px solid rgba(0,242,254,0.15);">
                        <td colspan="4" style="color:var(--text-muted);font-size:0.83rem;">
                            Tổng cộng (@(Model.TotalOrders - Model.CancelledOrders) đơn hợp lệ)
                        </td>
                        <td style="text-align:right;color:#00f2fe;">@Model.TotalRevenue.ToString("N0") ₫</td>
                        <td style="text-align:right;color:#10b981;">@Model.TotalPaid.ToString("N0") ₫</td>
                        <td style="text-align:right;color:@(Model.TotalDebt > 0 ? "#ef4444" : "#10b981");">
                            @(Model.TotalDebt > 0 ? Model.TotalDebt.ToString("N0") + " ₫" : "✓ Hết nợ")
                        </td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
