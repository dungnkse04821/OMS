@page
@model OMS.Pages.SupplySources.EditModel
@{
    ViewData["Title"] = "Sửa Nguồn hàng";
}

<div class="glass-card" style="max-width:600px;margin:0 auto;">
    <div class="mb-4">
        <a href="/SupplySources" style="color:var(--text-muted);font-size:0.85rem;text-decoration:none;">← Danh sách nguồn hàng</a>
        <h1 class="page-title" style="margin-top:8px;">✏️ Sửa Nguồn hàng</h1>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Source.Id" />
        <input type="hidden" asp-for="Source.CreatedAt" />

        <div class="form-group">
            <label asp-for="Source.Name" class="form-label"></label>
            <input asp-for="Source.Name" class="form-input" placeholder="Tên nguồn hàng..." />
            <span asp-validation-for="Source.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Source.Description" class="form-label"></label>
            <input asp-for="Source.Description" class="form-input" placeholder="Mô tả ngắn (tuỳ chọn)..." />
            <span asp-validation-for="Source.Description" class="text-danger"></span>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Source.SortOrder" class="form-label"></label>
                <input asp-for="Source.SortOrder" type="number" class="form-input" />
                <span asp-validation-for="Source.SortOrder" class="text-danger"></span>
            </div>
            <div class="form-group" style="display:flex;align-items:center;gap:12px;padding-top:28px;">
                <input asp-for="Source.IsActive" type="checkbox" style="width:18px;height:18px;accent-color:#00f2fe;cursor:pointer;" />
                <label asp-for="Source.IsActive" class="form-label" style="margin:0;cursor:pointer;"></label>
            </div>
        </div>

        <div style="display:flex;gap:12px;margin-top:24px;">
            <button type="submit" class="btn-premium" style="flex:1;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:17px;height:17px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Lưu thay đổi
            </button>
            <a href="/SupplySources" class="btn-secondary" style="flex:1;text-align:center;padding:12px;">Hủy</a>
        </div>
    </form>
</div>
